{
  "name": "@skyroc/ui",
  "type": "module",
  "version": "0.1.0",
  "private": false,
  "description": "A modern React UI component library for SoybeanAdmin",
  "author": {
    "name": "Soybean Admin Team",
    "url": "https://github.com/soybeanjs"
  },
  "license": "MIT",
  "homepage": "https://github.com/soybeanjs/soybean-admin-react/tree/main/ui-kit/ui",
  "repository": {
    "type": "git",
    "url": "https://github.com/soybeanjs/soybean-admin-react.git",
    "directory": "ui-kit/ui"
  },
  "bugs": {
    "url": "https://github.com/soybeanjs/soybean-admin-react/issues"
  },
  "keywords": [
    "react",
    "ui",
    "components",
    "design-system",
    "typescript",
    "soybean-admin",
    "antd",
    "component-library"
  ],
  "publishConfig": {
    "registry": "https://registry.npmjs.org/",
    "main": "./dist/index.js",
    "module": "./dist/index.js",
    "types": "./dist/index.d.ts",
    "exports": {
      ".": {
        "import": {
          "types": "./dist/index.d.ts",
          "default": "./dist/index.js"
        }
      },
      "./*": {
        "types": "./dist/components/*/index.d.ts",
        "import": "./dist/components/*/index.js"
      },
      "./hooks": {
        "types": "./dist/hooks/index.d.ts",
        "import": "./dist/hooks/index.js"
      },
      "./utils": {
        "types": "./dist/utils/index.d.ts",
        "import": "./dist/utils/index.js"
      }
    }
  },
  "sideEffects": false,
  "exports": {
    ".": {
      "import": "./src/index.ts"
    },
    "./hooks": {
      "import": "./src/hooks/index.ts"
    },
    "./utils": {
      "import": "./src/utils/index.ts"
    }
  },
  "main": "./src/index.ts",
  "module": "./src/index.ts",
  "types": "./src/index.ts",
  "files": ["dist", "README.md"],
  "scripts": {
    "build": "tsdown",
    "clean": "rimraf dist",
    "dev": "tsdown --watch",
    "lint": "eslint . --fix",
    "typecheck": "tsc --noEmit --skipLibCheck"
  },
  "peerDependencies": {
    "react": ">=18.0.0",
    "react-dom": ">=18.0.0"
  },
  "dependencies": {
    "@radix-ui/react-scroll-area": "^1.2.10",
    "@sa/color": "workspace:*",
    "@skyroc/utils": "workspace:*",
    "tailwind-variants": "^3.2.2"
  },
  "devDependencies": {
    "@soybeanjs/eslint-config": "^1.7.4",
    "@types/react": "^19.2.7",
    "@types/react-dom": "^19.2.3",
    "fast-glob": "^3.3.3",
    "react": "^19.2.1",
    "react-dom": "^19.2.1",
    "rimraf": "^6.0.1",
    "tsdown": "^0.18.2",
    "typescript": "5.9.3"
  }
}
