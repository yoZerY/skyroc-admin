{
  "name": "@skyroc/ui",
  "type": "module",
  "version": "0.1.0",
  "private": false,
  "description": "A modern React UI component library for SoybeanAdmin",
  "author": {
    "name": "Soybean Admin Team",
    "url": "https://github.com/soybeanjs"
  },
  "license": "MIT",
  "homepage": "https://github.com/soybeanjs/soybean-admin-react/tree/main/ui-kit/ui",
  "repository": {
    "type": "git",
    "url": "https://github.com/soybeanjs/soybean-admin-react.git",
    "directory": "ui-kit/ui"
  },
  "bugs": {
    "url": "https://github.com/soybeanjs/soybean-admin-react/issues"
  },
  "keywords": [
    "react",
    "ui",
    "components",
    "design-system",
    "typescript",
    "soybean-admin",
    "antd",
    "component-library"
  ],
  "sideEffects": false,
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "default": "./src/index.ts",
      "//default": "./dist/index.mjs",
      "development": "./src/index.ts"
    }
  },
  "main": "./src/index.ts",
  "module": "./src/index.ts",
  "types": "./src/index.ts",
  "files": ["dist", "README.md"],
  "scripts": {
    "build": "tsdown",
    "clean": "rimraf dist",
    "dev": "tsdown --watch",
    "lint": "eslint . --fix",
    "typecheck": "tsc --noEmit --skipLibCheck"
  },
  "peerDependencies": {
    "react": ">=19.0.0",
    "react-dom": ">=19.0.0"
  },
  "dependencies": {
    "@radix-ui/react-scroll-area": "^1.2.10",
    "@sa/color": "workspace:*",
    "@skyroc/utils": "workspace:*",
    "react": "^19.2.1",
    "react-dom": "^19.2.1",
    "tailwind-variants": "^3.2.2"
  },
  "devDependencies": {
    "@soybeanjs/eslint-config": "^1.7.4",
    "@types/react": "^19.2.7",
    "@types/react-dom": "^19.2.3",
    "rimraf": "^6.0.1",
    "tsdown": "^0.18.2",
    "typescript": "5.9.3"
  }
}
