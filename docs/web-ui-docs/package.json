{
  "name": "web-ui-docs",
  "version": "0.0.0",
  "private": true,
  "scripts": {
    "build": "next build",
    "cf-typegen": "wrangler types --env-interface CloudflareEnv cloudflare-env.d.ts",
    "deploy": "pnpm run worker:build && opennextjs-cloudflare deploy",
    "dev": "next dev",
    "start": "next start",
    "preview": "opennextjs-cloudflare build && opennextjs-cloudflare preview",
    "types:check": "fumadocs-mdx && next typegen && tsc --noEmit",
    "postinstall": "fumadocs-mdx",
    "lint": "oxlint --fix",
    "upload": "opennextjs-cloudflare build && opennextjs-cloudflare upload",
    "worker:build": "opennextjs-cloudflare build"
  },
  "dependencies": {
    "@ai-sdk/react": "^3.0.170",
    "@openrouter/ai-sdk-provider": "^2.8.0",
    "@radix-ui/react-presence": "^1.1.5",
    "@skyroc/web-ui": "workspace:*",
    "ai": "^6.0.168",
    "async-validator": "^4.2.5",
    "class-variance-authority": "^0.7.1",
    "flexsearch": "^0.8.212",
    "fumadocs-core": "16.8.3",
    "fumadocs-mdx": "14.3.1",
    "fumadocs-ui": "16.8.3",
    "hast-util-to-jsx-runtime": "^2.3.6",
    "lucide-react": "^1.9.0",
    "next": "16.2.4",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "react-live": "^4.1.8",
    "remark": "^15.0.1",
    "remark-gfm": "^4.0.1",
    "remark-rehype": "^11.1.2",
    "tailwind-merge": "^3.5.0",
    "unist-util-visit": "^5.1.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@opennextjs/cloudflare": "1.13.1",
    "@skyroc/tailwind-plugin": "workspace:*",
    "@tailwindcss/postcss": "^4.2.4",
    "@types/hast": "^3.0.4",
    "@types/mdx": "^2.0.13",
    "@types/node": "^25.6.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "oxlint": "^1.61.0",
    "postcss": "^8.5.10",
    "tailwindcss": "^4.2.4",
    "tw-animate-css": "^1.4.0",
    "typescript": "catalog:core",
    "wrangler": "4.51.0"
  }
}
