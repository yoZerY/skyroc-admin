{
  "name": "core-docs",
  "version": "0.0.0",
  "private": true,
  "scripts": {
    "build": "next build",
    "cf-typegen": "wrangler types --env-interface CloudflareEnv cloudflare-env.d.ts",
    "deploy": "pnpm run worker:build && opennextjs-cloudflare deploy",
    "dev": "next dev",
    "start": "next start",
    "preview": "opennextjs-cloudflare build && opennextjs-cloudflare preview",
    "types:check": "fumadocs-mdx && next typegen && tsc --noEmit",
    "postinstall": "fumadocs-mdx",
    "lint": "oxlint",
    "upload": "opennextjs-cloudflare build && opennextjs-cloudflare upload",
    "worker:build": "opennextjs-cloudflare build"
  },
  "dependencies": {
    "@orama/orama": "^3.1.18",
    "fumadocs-core": "16.7.14",
    "fumadocs-mdx": "14.2.13",
    "fumadocs-ui": "16.7.14",
    "lucide-react": "^1.8.0",
    "next": "16.2.3",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "tailwind-merge": "^3.5.0"
  },
  "devDependencies": {
    "@opennextjs/cloudflare": "1.13.1",
    "@tailwindcss/postcss": "^4.2.2",
    "@types/mdx": "^2.0.13",
    "@types/node": "^25.6.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "oxlint": "catalog:dev",
    "postcss": "^8.5.9",
    "tailwindcss": "^4.2.2",
    "typescript": "catalog:core",
    "wrangler": "4.51.0"
  }
}
