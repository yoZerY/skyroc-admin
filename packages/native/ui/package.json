{
  "name": "@skyroc/native-ui",
  "type": "module",
  "version": "0.1.0",
  "private": false,
  "description": "React Native component library with NativeWind styling",
  "license": "MIT",
  "sideEffects": false,
  "exports": {
    ".": "./src/index.ts"
  },
  "main": "./src/index.ts",
  "module": "./src/index.ts",
  "types": "./src/index.ts",
  "files": ["dist"],
  "scripts": {
    "build": "tsdown",
    "clean": "rimraf dist",
    "test": "jest",
    "test:watch": "jest --watch",
    "typecheck": "tsc --noEmit --skipLibCheck"
  },
  "peerDependencies": {
    "@gorhom/bottom-sheet": ">=5.0.0",
    "expo-image": ">=3.0.0",
    "nativewind": ">=4.1.0",
    "react": ">=18",
    "react-native": ">=0.74",
    "react-native-gesture-handler": ">=2.0.0",
    "react-native-modal": ">=13.0.0",
    "react-native-reanimated": ">=3.0.0"
  },
  "peerDependenciesMeta": {
    "@gorhom/bottom-sheet": {
      "optional": true
    },
    "expo-image": {
      "optional": true
    },
    "react-native-gesture-handler": {
      "optional": true
    },
    "react-native-modal": {
      "optional": true
    },
    "react-native-reanimated": {
      "optional": true
    }
  },
  "dependencies": {
    "@radix-ui/react-use-controllable-state": "^1.2.2",
    "@rn-primitives/slot": "^1.2.0",
    "@skyroc/hooks": "workspace:*",
    "@skyroc/native-theme": "workspace:*",
    "@skyroc/ui-types": "workspace:*",
    "@skyroc/utils": "workspace:*",
    "react": "catalog:core",
    "react-native-modal": "catalog:native",
    "tailwind-variants": "catalog:utils"
  },
  "devDependencies": {
    "@skyroc/tsconfig": "workspace:*",
    "@testing-library/react-native": "catalog:native",
    "@types/react": "catalog:dev",
    "jest": "^29.7.0",
    "react-native": "catalog:native",
    "react-test-renderer": "^18.3.1"
  }
}
