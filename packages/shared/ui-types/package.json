{
  "name": "@skyroc/ui-types",
  "version": "0.1.0",
  "private": false,
  "type": "module",
  "description": "Shared UI type definitions for cross-platform components",
  "keywords": [
    "cross-platform",
    "design-system",
    "react",
    "skyroc",
    "types",
    "typescript",
    "ui"
  ],
  "license": "MIT",
  "homepage": "https://github.com/Ohh-889/skyroc-admin/tree/master/packages/shared/ui-types",
  "bugs": {
    "url": "https://github.com/Ohh-889/skyroc-admin/issues"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/Ohh-889/skyroc-admin.git",
    "directory": "packages/shared/ui-types"
  },
  "author": {
    "name": "Ohh",
    "email": "1509326266@qq.com",
    "url": "https://github.com/Ohh-889"
  },
  "sideEffects": false,
  "files": [
    "dist",
    "README.md"
  ],
  "main": "./src/index.ts",
  "module": "./src/index.ts",
  "types": "./src/index.ts",
  "typesVersions": {
    "*": {
      "*": [
        "./src/*"
      ]
    }
  },
  "exports": {
    ".": "./src/index.ts"
  },
  "publishConfig": {
    "registry": "https://registry.npmjs.org/",
    "access": "public",
    "main": "./dist/index.js",
    "module": "./dist/index.js",
    "types": "./dist/index.d.ts",
    "exports": {
      ".": {
        "import": {
          "types": "./dist/index.d.ts",
          "default": "./dist/index.js"
        }
      }
    }
  },
  "scripts": {
    "build": "tsdown",
    "clean": "rimraf dist",
    "dev": "tsdown --watch",
    "typecheck": "tsc --noEmit --skipLibCheck"
  },
  "dependencies": {
    "clsx": "catalog:utils"
  },
  "devDependencies": {
    "@skyroc/tsconfig": "workspace:*",
    "rimraf": "catalog:dev",
    "tsdown": "catalog:dev"
  }
}
