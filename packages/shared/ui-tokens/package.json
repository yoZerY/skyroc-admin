{
  "name": "@skyroc/ui-tokens",
  "version": "0.1.1",
  "private": false,
  "type": "module",
  "description": "Cross-platform design tokens: colors, spacing, radius, typography. Zero runtime dependencies.",
  "keywords": [
    "cross-platform",
    "design-system",
    "design-tokens",
    "nativewind",
    "skyroc",
    "soybean-admin",
    "tailwind",
    "ui"
  ],
  "license": "MIT",
  "homepage": "https://github.com/Ohh-889/skyroc-admin/tree/master/packages/shared/ui-tokens",
  "bugs": {
    "url": "https://github.com/Ohh-889/skyroc-admin/issues"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/Ohh-889/skyroc-admin.git",
    "directory": "packages/shared/ui-tokens"
  },
  "author": {
    "name": "Ohh",
    "email": "1509326266@qq.com",
    "url": "https://github.com/Ohh-889"
  },
  "sideEffects": false,
  "files": [
    "dist",
    "README.md"
  ],
  "main": "./src/index.ts",
  "module": "./src/index.ts",
  "types": "./src/index.ts",
  "typesVersions": {
    "*": {
      "colors": [
        "./src/colors.ts"
      ],
      "radius": [
        "./src/radius.ts"
      ],
      "spacing": [
        "./src/spacing.ts"
      ],
      "typography": [
        "./src/typography.ts"
      ]
    }
  },
  "exports": {
    ".": "./src/index.ts",
    "./colors": "./src/colors.ts",
    "./radius": "./src/radius.ts",
    "./spacing": "./src/spacing.ts",
    "./typography": "./src/typography.ts"
  },
  "publishConfig": {
    "registry": "https://registry.npmjs.org/",
    "access": "public",
    "main": "./dist/index.js",
    "module": "./dist/index.js",
    "types": "./dist/index.d.ts",
    "exports": {
      ".": {
        "import": {
          "types": "./dist/index.d.ts",
          "default": "./dist/index.js"
        }
      },
      "./colors": {
        "import": {
          "types": "./dist/colors.d.ts",
          "default": "./dist/colors.js"
        }
      },
      "./radius": {
        "import": {
          "types": "./dist/radius.d.ts",
          "default": "./dist/radius.js"
        }
      },
      "./spacing": {
        "import": {
          "types": "./dist/spacing.d.ts",
          "default": "./dist/spacing.js"
        }
      },
      "./typography": {
        "import": {
          "types": "./dist/typography.d.ts",
          "default": "./dist/typography.js"
        }
      }
    }
  },
  "scripts": {
    "build": "tsdown",
    "clean": "rimraf dist",
    "dev": "tsdown --watch",
    "typecheck": "tsc --noEmit --skipLibCheck"
  },
  "devDependencies": {
    "@skyroc/tsconfig": "workspace:*",
    "rimraf": "catalog:dev",
    "tsdown": "catalog:dev"
  }
}