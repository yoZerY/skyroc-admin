{
  "name": "@skyroc/ui-tokens",
  "version": "0.1.0",
  "private": false,
  "description": "Cross-platform design tokens: colors, spacing, radius, typography. Zero runtime dependencies.",
  "keywords": [
    "design-tokens",
    "design-system",
    "cross-platform",
    "soybean-admin",
    "ui",
    "tailwind",
    "nativewind"
  ],
  "license": "MIT",
  "files": [
    "dist",
    "README.md"
  ],
  "type": "module",
  "sideEffects": false,
  "main": "./src/index.ts",
  "module": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": "./src/index.ts",
    "./colors": "./src/colors.ts",
    "./spacing": "./src/spacing.ts",
    "./radius": "./src/radius.ts",
    "./typography": "./src/typography.ts"
  },
  "scripts": {
    "build": "tsdown",
    "clean": "rimraf dist",
    "typecheck": "tsc --noEmit --skipLibCheck"
  },
  "devDependencies": {
    "@skyroc/tsconfig": "workspace:*"
  }
}
