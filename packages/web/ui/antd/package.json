{
  "name": "@skyroc/web-ui-antd",
  "version": "0.1.0",
  "private": false,
  "description": "Ant Design composite components for admin applications",
  "keywords": [
    "admin",
    "antd",
    "components",
    "react",
    "soybean-admin",
    "typescript",
    "ui"
  ],
  "homepage": "https://github.com/soybeanjs/soybean-admin-react/tree/main/packages/ui/antd",
  "bugs": {
    "url": "https://github.com/soybeanjs/soybean-admin-react/issues"
  },
  "license": "MIT",
  "author": {
    "name": "Soybean Admin Team",
    "url": "https://github.com/soybeanjs"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/soybeanjs/soybean-admin-react.git",
    "directory": "packages/ui/antd"
  },
  "files": [
    "dist",
    "README.md"
  ],
  "type": "module",
  "sideEffects": [
    "**/*.css"
  ],
  "main": "./src/index.ts",
  "module": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": "./src/index.ts"
  },
  "publishConfig": {
    "registry": "https://registry.npmjs.org/",
    "access": "public",
    "main": "./dist/index.js",
    "module": "./dist/index.js",
    "types": "./dist/index.d.ts",
    "exports": {
      ".": {
        "import": {
          "types": "./dist/index.d.ts",
          "default": "./dist/index.js"
        }
      }
    }
  },
  "scripts": {
    "build": "tsdown",
    "clean": "rimraf dist",
    "dev": "tsdown --watch",
    "lint": "oxlint --fix",
    "typecheck": "tsc --noEmit --skipLibCheck"
  },
  "dependencies": {
    "@iconify/react": "catalog:ui-shared",
    "@skyroc/web-ui-compose": "workspace:*",
    "clsx": "catalog:utils"
  },
  "peerDependencies": {
    "@tanstack/react-router": "^1.140.0",
    "antd": ">=6.0.0",
    "react": "^18.0.0 || ^19.0.0",
    "react-dom": "^18.0.0 || ^19.0.0",
    "react-error-boundary": "^6.0.0"
  },
  "devDependencies": {
    "@soybeanjs/eslint-config": "catalog:dev",
    "@tanstack/react-router": "catalog:web",
    "@types/react": "catalog:dev",
    "@types/react-dom": "catalog:dev",
    "antd": "catalog:web",
    "oxlint": "catalog:dev",
    "react": "catalog:core",
    "react-dom": "catalog:core",
    "react-error-boundary": "catalog:core",
    "rimraf": "catalog:dev",
    "tsdown": "catalog:dev",
    "typescript": "catalog:core"
  }
}
