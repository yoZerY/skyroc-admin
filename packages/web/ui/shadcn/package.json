{
  "name": "@skyroc/web-ui",
  "version": "0.1.0",
  "private": false,
  "description": "A modern React UI component library built on Radix UI and Tailwind CSS for SoybeanAdmin",
  "keywords": [
    "antd",
    "component-library",
    "components",
    "design-system",
    "radix-ui",
    "react",
    "react-components",
    "shadcn",
    "soybean-admin",
    "tailwind",
    "tailwindcss",
    "typescript",
    "ui",
    "ui-library"
  ],
  "homepage": "https://github.com/soybeanjs/soybean-admin-react/tree/main/packages/web/ui/shadcn",
  "bugs": {
    "url": "https://github.com/soybeanjs/soybean-admin-react/issues"
  },
  "license": "MIT",
  "author": {
    "name": "Soybean Admin Team",
    "url": "https://github.com/soybeanjs"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/soybeanjs/soybean-admin-react.git",
    "directory": "packages/web/ui/shadcn"
  },
  "files": [
    "dist",
    "README.md"
  ],
  "type": "module",
  "sideEffects": false,
  "main": "./src/index.ts",
  "module": "./src/index.ts",
  "types": "./src/index.ts",
  "typesVersions": {
    "*": {
      "primitives": [
        "./src/components/index.ts"
      ]
    }
  },
  "exports": {
    ".": "./src/index.ts",
    "./primitives": "./src/components/index.ts"
  },
  "publishConfig": {
    "registry": "https://registry.npmjs.org/",
    "access": "public",
    "main": "./dist/index.js",
    "module": "./dist/index.js",
    "types": "./dist/index.d.ts",
    "exports": {
      ".": {
        "import": {
          "types": "./dist/index.d.ts",
          "default": "./dist/index.js"
        }
      },
      "./primitives": {
        "import": {
          "types": "./dist/components/index.d.ts",
          "default": "./dist/components/index.js"
        }
      }
    }
  },
  "scripts": {
    "build": "tsdown",
    "clean": "rimraf dist",
    "dev": "tsdown --watch",
    "lint": "oxlint --fix",
    "typecheck": "tsc --noEmit --skipLibCheck"
  },
  "dependencies": {
    "@formkit/auto-animate": "^0.9.0",
    "@iconify/react": "catalog:ui-shared",
    "@radix-ui/react-accordion": "^1.2.12",
    "@radix-ui/react-alert-dialog": "^1.1.15",
    "@radix-ui/react-arrow": "^1.1.8",
    "@radix-ui/react-aspect-ratio": "^1.1.7",
    "@radix-ui/react-avatar": "^1.1.11",
    "@radix-ui/react-checkbox": "^1.3.3",
    "@radix-ui/react-collapsible": "^1.1.12",
    "@radix-ui/react-compose-refs": "^1.1.2",
    "@radix-ui/react-context-menu": "^2.2.16",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-dropdown-menu": "^2.1.16",
    "@radix-ui/react-hover-card": "^1.1.15",
    "@radix-ui/react-label": "^2.1.8",
    "@radix-ui/react-menu": "^2.1.16",
    "@radix-ui/react-menubar": "^1.1.16",
    "@radix-ui/react-navigation-menu": "^1.2.14",
    "@radix-ui/react-popover": "^1.1.15",
    "@radix-ui/react-progress": "^1.1.8",
    "@radix-ui/react-radio-group": "^1.3.8",
    "@radix-ui/react-scroll-area": "catalog:ui-shared",
    "@radix-ui/react-select": "^2.2.6",
    "@radix-ui/react-separator": "^1.1.8",
    "@radix-ui/react-slider": "^1.3.6",
    "@radix-ui/react-slot": "^1.2.4",
    "@radix-ui/react-switch": "^1.2.6",
    "@radix-ui/react-tabs": "^1.1.13",
    "@radix-ui/react-toggle": "^1.1.10",
    "@radix-ui/react-toggle-group": "^1.1.11",
    "@radix-ui/react-tooltip": "catalog:ui-shared",
    "@radix-ui/react-use-controllable-state": "^1.2.2",
    "@skyroc/color": "workspace:*",
    "@skyroc/ui-types": "workspace:*",
    "@skyroc/utils": "workspace:*",
    "@tanstack/react-virtual": "^3.13.24",
    "cmdk": "^1.1.1",
    "embla-carousel-react": "^8.6.0",
    "input-otp": "^1.4.2",
    "lucide-react": "^0.545.0",
    "react-resizable-panels": "^4.10.0",
    "sonner": "^2.0.7",
    "@skyroc/form": "workspace:*",
    "tailwind-variants": "catalog:utils",
    "vaul": "^1.1.2"
  },
  "peerDependencies": {
    "@skyroc/tailwind-plugin": "workspace:*",
    "react": "^18.0.0 || ^19.0.0",
    "react-dom": "^18.0.0 || ^19.0.0"
  },
  "devDependencies": {
    "@skyroc/tsconfig": "workspace:*",
    "@soybeanjs/eslint-config": "catalog:dev",
    "@types/react": "catalog:dev",
    "@types/react-dom": "catalog:dev",
    "oxlint": "catalog:dev",
    "react": "catalog:core",
    "react-dom": "catalog:core",
    "rimraf": "catalog:dev",
    "tsdown": "catalog:dev"
  }
}