{
  "name": "@skyroc/web-ui-compose",
  "version": "0.1.0",
  "private": false,
  "description": "Composite stateless UI components built on @skyroc/ui primitives",
  "keywords": [
    "components",
    "composite",
    "react",
    "soybean-admin",
    "typescript",
    "ui"
  ],
  "homepage": "https://github.com/soybeanjs/soybean-admin-react/tree/main/packages/ui/compose",
  "bugs": {
    "url": "https://github.com/soybeanjs/soybean-admin-react/issues"
  },
  "license": "MIT",
  "author": {
    "name": "Soybean Admin Team",
    "url": "https://github.com/soybeanjs"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/soybeanjs/soybean-admin-react.git",
    "directory": "packages/ui/compose"
  },
  "files": [
    "dist",
    "README.md"
  ],
  "type": "module",
  "sideEffects": false,
  "main": "./src/index.ts",
  "module": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": "./src/index.ts"
  },
  "publishConfig": {
    "registry": "https://registry.npmjs.org/",
    "access": "public",
    "main": "./dist/index.js",
    "module": "./dist/index.js",
    "types": "./dist/index.d.ts",
    "exports": {
      ".": {
        "import": {
          "types": "./dist/index.d.ts",
          "default": "./dist/index.js"
        }
      }
    }
  },
  "scripts": {
    "build": "tsdown",
    "clean": "rimraf dist",
    "dev": "tsdown --watch",
    "lint": "oxlint --fix",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit --skipLibCheck"
  },
  "dependencies": {
    "@better-scroll/core": "catalog:web",
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "@iconify/react": "catalog:ui-shared",
    "@skyroc/color": "workspace:*",
    "@skyroc/utils": "workspace:*",
    "ahooks": "catalog:utils",
    "clsx": "catalog:utils",
    "tailwind-variants": "catalog:utils"
  },
  "peerDependencies": {
    "antd": ">=6.0.0",
    "i18next": "^25.0.0",
    "motion": "^12.0.0",
    "react": "^18.0.0 || ^19.0.0",
    "react-dom": "^18.0.0 || ^19.0.0",
    "react-i18next": "^16.0.0"
  },
  "devDependencies": {
    "@skyroc/config": "workspace:*",
    "@skyroc/types": "workspace:*",
    "@soybeanjs/eslint-config": "catalog:dev",
    "@testing-library/jest-dom": "catalog:dev",
    "@testing-library/react": "catalog:dev",
    "@types/react": "catalog:dev",
    "@types/react-dom": "catalog:dev",
    "antd": "catalog:web",
    "i18next": "catalog:i18n",
    "motion": "catalog:ui-shared",
    "oxlint": "catalog:dev",
    "react": "catalog:core",
    "react-dom": "catalog:core",
    "react-i18next": "catalog:i18n",
    "typescript": "catalog:core",
    "vitest": "catalog:dev"
  }
}
