{
  "name": "@skyroc/web-admin-runtime",
  "version": "1.0.0",
  "type": "module",
  "description": "Reusable web admin runtime helpers for bootstrap and request adapters.",
  "keywords": [
    "admin",
    "bootstrap",
    "dayjs",
    "iconify",
    "nprogress",
    "request",
    "runtime",
    "skyroc",
    "web"
  ],
  "license": "MIT",
  "homepage": "https://github.com/Ohh-889/skyroc-admin/tree/master/packages/web/admin-runtime",
  "bugs": {
    "url": "https://github.com/Ohh-889/skyroc-admin/issues"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/Ohh-889/skyroc-admin.git",
    "directory": "packages/web/admin-runtime"
  },
  "author": {
    "name": "Ohh",
    "email": "1509326266@qq.com",
    "url": "https://github.com/Ohh-889"
  },
  "sideEffects": false,
  "files": [
    "dist",
    "README.md"
  ],
  "main": "./src/index.ts",
  "module": "./src/index.ts",
  "types": "./src/index.ts",
  "typesVersions": {
    "*": {
      "*": [
        "./src/*"
      ]
    }
  },
  "exports": {
    ".": "./src/index.ts"
  },
  "publishConfig": {
    "registry": "https://registry.npmjs.org/",
    "access": "public",
    "main": "./dist/index.js",
    "module": "./dist/index.js",
    "types": "./dist/index.d.ts",
    "exports": {
      ".": {
        "import": {
          "types": "./dist/index.d.ts",
          "default": "./dist/index.js"
        }
      }
    }
  },
  "scripts": {
    "build": "tsdown",
    "clean": "rimraf dist",
    "dev": "tsdown --watch",
    "lint": "oxlint --fix",
    "test": "vitest run",
    "typecheck": "tsc --noEmit --skipLibCheck"
  },
  "dependencies": {
    "@skyroc/service": "workspace:*"
  },
  "devDependencies": {
    "@iconify/react": "catalog:ui-shared",
    "@skyroc/config": "workspace:*",
    "@skyroc/tsconfig": "workspace:*",
    "@skyroc/types": "workspace:*",
    "@types/nprogress": "catalog:dev",
    "@types/react": "catalog:dev",
    "dayjs": "catalog:utils",
    "nprogress": "catalog:ui-shared",
    "oxlint": "catalog:dev",
    "react": "catalog:core",
    "rimraf": "catalog:dev",
    "tsdown": "catalog:dev",
    "typescript": "catalog:core",
    "vitest": "catalog:dev"
  },
  "peerDependencies": {
    "@iconify/react": ">=6.0.0",
    "dayjs": ">=1.11.0",
    "nprogress": ">=0.2.0",
    "react": ">=18.0.0"
  }
}
