{
  "extends": "@skyroc/tsconfig/web.json",
  "compilerOptions": {
    "outDir": "./dist",
    "rootDir": ".",
    "types": [
      "vite/client",
      "@skyroc/types/types",
      "@skyroc/web-admin-theme/types",
      "vitest/globals",
      "@testing-library/jest-dom"
    ]
  },
  "include": [
    "src/**/*",
    "__tests__/**/*",
    "vitest.config.ts",
    "vitest.setup.ts",
    "tsdown.config.ts",
    "../../@core/types/src/**/*.d.ts"
  ],
  "exclude": ["node_modules", "dist"]
}
