{
  "name": "shadcn",
  "desc": "Modern and elegant theme inspired by shadcn/ui design system with neutral tones",
  "i18nkey": "theme.appearance.preset.shadcn",
  "version": "1.0.0",
  "order": 3,
  "themeScheme": "light",
  "grayscale": false,
  "colourWeakness": false,
  "recommendColor": false,
  "themeColor": "#18181b",
  "otherColor": {
    "info": "#0ea5e9",
    "success": "#10b981",
    "warning": "#f59e0b",
    "error": "#ef4444"
  },
  "themeRadius": 8,
  "themeTextSize": 14,
  "isInfoFollowPrimary": false,
  "layout": {
    "mode": "vertical",
    "scrollMode": "content"
  },
  "page": {
    "animate": true,
    "animateMode": "fade-slide"
  },
  "header": {
    "height": 56,
    "breadcrumb": {
      "visible": true,
      "showIcon": true
    },
    "multilingual": {
      "visible": true
    },
    "globalSearch": {
      "visible": true
    }
  },
  "tab": {
    "visible": true,
    "cache": true,
    "height": 44,
    "mode": "chrome",
    "closeTabByMiddleClick": true
  },
  "fixedHeaderAndTab": true,
  "sider": {
    "inverted": false,
    "width": 240,
    "collapsedWidth": 64,
    "mixWidth": 90,
    "mixCollapsedWidth": 64,
    "mixChildMenuWidth": 200,
    "autoSelectFirstMenu": true
  },
  "footer": {
    "visible": true,
    "fixed": false,
    "height": 48,
    "right": true
  },
  "watermark": {
    "visible": false,
    "text": "SoybeanAdmin",
    "enableUserName": false,
    "enableTime": false,
    "timeFormat": "YYYY-MM-DD HH:mm"
  },
  "tokens": {
    "light": {
      "colors": {
        "container": "rgb(255, 255, 255)",
        "layout": "rgb(250, 250, 250)",
        "inverted": "rgb(9, 9, 11)",
        "base-text": "rgb(24, 24, 27)"
      },
      "boxShadow": {
        "header": "0 1px 3px 0 rgb(0, 0, 0, 0.1), 0 1px 2px -1px rgb(0, 0, 0, 0.1)",
        "sider": "1px 0 3px 0 rgb(0, 0, 0, 0.1)",
        "tab": "0 1px 3px 0 rgb(0, 0, 0, 0.1), 0 1px 2px -1px rgb(0, 0, 0, 0.1)"
      }
    },
    "dark": {
      "colors": {
        "container": "rgb(24, 24, 27)",
        "layout": "rgb(9, 9, 11)",
        "base-text": "rgb(250, 250, 250)"
      },
      "boxShadow": {
        "header": "0 1px 3px 0 rgb(0, 0, 0, 0.3), 0 1px 2px -1px rgb(0, 0, 0, 0.3)",
        "sider": "1px 0 3px 0 rgb(0, 0, 0, 0.3)",
        "tab": "0 1px 3px 0 rgb(0, 0, 0, 0.3), 0 1px 2px -1px rgb(0, 0, 0, 0.3)"
      }
    }
  }
}
