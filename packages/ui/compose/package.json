{
  "name": "@skyroc/ui-compose",
  "type": "module",
  "version": "0.1.0",
  "private": false,
  "description": "Composite stateless UI components built on @skyroc/ui primitives",
  "author": {
    "name": "Soybean Admin Team",
    "url": "https://github.com/soybeanjs"
  },
  "license": "MIT",
  "homepage": "https://github.com/soybeanjs/soybean-admin-react/tree/main/packages/ui/compose",
  "repository": {
    "type": "git",
    "url": "https://github.com/soybeanjs/soybean-admin-react.git",
    "directory": "packages/ui/compose"
  },
  "bugs": {
    "url": "https://github.com/soybeanjs/soybean-admin-react/issues"
  },
  "keywords": [
    "react",
    "ui",
    "components",
    "composite",
    "typescript",
    "soybean-admin"
  ],
  "sideEffects": false,
  "exports": {
    ".": "./src/index.ts"
  },
  "main": "./src/index.ts",
  "module": "./src/index.ts",
  "types": "./src/index.ts",
  "files": ["dist", "README.md"],
  "scripts": {
    "build": "tsdown",
    "clean": "rimraf dist",
    "dev": "tsdown --watch",
    "lint": "eslint . --fix",
    "typecheck": "tsc --noEmit --skipLibCheck"
  },
  "dependencies": {
    "@better-scroll/core": "catalog:web",
    "@iconify/react": "catalog:ui-shared",
    "@skyroc/color": "workspace:*",
    "@skyroc/ui": "workspace:*",
    "@skyroc/utils": "workspace:*",
    "ahooks": "catalog:utils",
    "clsx": "catalog:utils",
    "i18next": "catalog:i18n",
    "motion": "catalog:ui-shared",
    "react": "catalog:core",
    "react-dom": "catalog:core",
    "react-i18next": "catalog:i18n",
    "tailwind-variants": "catalog:utils"
  },
  "devDependencies": {
    "@soybeanjs/eslint-config": "catalog:dev",
    "@types/react": "catalog:dev",
    "@types/react-dom": "catalog:dev"
  }
}
