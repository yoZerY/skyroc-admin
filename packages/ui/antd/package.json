{
  "name": "@skyroc/ui-antd",
  "type": "module",
  "version": "0.1.0",
  "private": false,
  "description": "Ant Design composite components for admin applications",
  "author": {
    "name": "Soybean Admin Team",
    "url": "https://github.com/soybeanjs"
  },
  "license": "MIT",
  "homepage": "https://github.com/soybeanjs/soybean-admin-react/tree/main/packages/ui/antd",
  "repository": {
    "type": "git",
    "url": "https://github.com/soybeanjs/soybean-admin-react.git",
    "directory": "packages/ui/antd"
  },
  "bugs": {
    "url": "https://github.com/soybeanjs/soybean-admin-react/issues"
  },
  "keywords": ["react", "antd", "ui", "components", "admin", "typescript", "soybean-admin"],
  "sideEffects": ["**/*.css"],
  "exports": {
    ".": "./src/index.ts"
  },
  "main": "./src/index.ts",
  "module": "./src/index.ts",
  "types": "./src/index.ts",
  "files": ["dist", "README.md"],
  "scripts": {
    "build": "tsdown",
    "clean": "rimraf dist",
    "dev": "tsdown --watch",
    "lint": "eslint . --fix",
    "typecheck": "tsc --noEmit --skipLibCheck"
  },
  "dependencies": {
    "@iconify/react": "catalog:ui-shared",
    "@skyroc/ui": "workspace:*",
    "@skyroc/ui-compose": "workspace:*",
    "@skyroc/utils": "workspace:*",
    "@tanstack/react-router": "catalog:web",
    "antd": "catalog:web",
    "clsx": "catalog:utils",
    "react": "catalog:core",
    "react-dom": "catalog:core",
    "react-error-boundary": "catalog:core"
  },
  "devDependencies": {
    "@soybeanjs/eslint-config": "catalog:dev",
    "@types/react": "catalog:dev",
    "@types/react-dom": "catalog:dev"
  }
}
